{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@velicot/editor": ["../../packages/editor/src/index.ts"],
      "@velicot/export": ["../../packages/export/src/index.ts"],
      "@velicot/fsm": ["../../packages/fsm/src/index.ts"]
    }
  },
  "include": [
    "src",
    "../../packages/editor/src",
    "../../packages/export/src",
    "../../packages/fsm/src"
  ],
  "exclude": [
    "../../packages/editor/src/**/__tests__",
    "../../packages/editor/src/**/*.test.ts",
    "../../packages/export/src/**/__tests__",
    "../../packages/export/src/**/*.test.ts",
    "../../packages/fsm/src/**/__tests__",
    "../../packages/fsm/src/**/*.test.ts"
  ]
}
